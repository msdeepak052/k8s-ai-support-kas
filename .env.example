# ─────────────────────────────────────────────────────────────────────────────
# k8s-ai-support Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════
#  LLM API KEYS (provide at least one)
# ══════════════════════════════════════════════

# OpenAI (GPT-4o, GPT-4o-mini, etc.)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Google Gemini (gemini-1.5-pro, gemini-1.5-flash)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Anthropic Claude (claude-3-5-sonnet, claude-3-5-haiku)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...


# ══════════════════════════════════════════════
#  LLM PROVIDER CONFIGURATION
# ══════════════════════════════════════════════

# Provider: openai | gemini | claude | ollama
K8S_AI_PROVIDER=openai

# Model name (must match provider)
# OpenAI: gpt-4o-mini | gpt-4o | gpt-3.5-turbo
# Gemini:  gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash
# Claude:  claude-3-5-sonnet-20241022 | claude-3-5-haiku-20241022
# Ollama:  llama3.1 | qwen2.5 | mistral
K8S_AI_MODEL=gpt-4o-mini

# Temperature (0.0 = deterministic, 1.0 = creative)
# Recommended: 0.1 for diagnosis (we want consistency)
K8S_AI_TEMPERATURE=0.1

# Ollama server URL (for local LLM, air-gapped environments)
K8S_AI_OLLAMA_URL=http://localhost:11434


# ══════════════════════════════════════════════
#  KUBERNETES CONFIGURATION
# ══════════════════════════════════════════════

# Path to kubeconfig (defaults to ~/.kube/config)
# KUBECONFIG=/path/to/kubeconfig

# Default namespace when none specified
K8S_AI_DEFAULT_NAMESPACE=default

# kubectl command timeout (seconds)
K8S_AI_KUBECTL_TIMEOUT=10


# ══════════════════════════════════════════════
#  TOKEN BUDGET (important for cost control)
# ══════════════════════════════════════════════

# Max tokens to send to LLM per request (default: 8000)
# Higher = more context but higher cost
K8S_AI_TOKEN_BUDGET=8000

# Max log lines to include per container (default: 10)
K8S_AI_MAX_LOG_LINES=10

# Max RAG chunks to retrieve (default: 3)
K8S_AI_RAG_TOP_K=3


# ══════════════════════════════════════════════
#  LOGGING
# ══════════════════════════════════════════════

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
K8S_AI_LOG_LEVEL=INFO

# Log format: json (structured) | text (human-readable)
K8S_AI_LOG_FORMAT=json


# ══════════════════════════════════════════════
#  MCP SERVER
# ══════════════════════════════════════════════

# Rate limit for MCP server (requests per minute)
K8S_AI_MCP_RATE_LIMIT=10


# ══════════════════════════════════════════════
#  RAG / EMBEDDINGS
# ══════════════════════════════════════════════

# Embedding model (HuggingFace, runs locally, no API key needed)
# Alternatives: all-MiniLM-L6-v2 (faster), BAAI/bge-large-en (more accurate)
K8S_AI_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Vector store type: chroma | faiss
K8S_AI_VECTOR_STORE_TYPE=chroma

# Cache directory for embeddings (default: ~/.cache/k8s-ai)
# K8S_AI_CACHE_DIR=/path/to/cache


# ══════════════════════════════════════════════
#  OUTPUT
# ══════════════════════════════════════════════

# Default output format: json | yaml | table
K8S_AI_OUTPUT_FORMAT=table
